{
  "name": "ticketbasics",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@10.30.1",
  "description": "ticket system",
  "author": "Milad Soltani",
  "license": "ISC",
  "keywords": [],
  "main": "index.js",
  "engines": {
    "node": ">=22.20.0"
  },
  "scripts": {
    "dev:backend": "cd ./backend && npm run dev",
    "dev:frontend": "cd ./frontend && npm run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "lint": "eslint backend/src frontend/src",
    "lint:fix": "eslint backend/src frontend/src --fix",
    "generate": "cd ./backend && npx drizzle-kit generate",
    "migrate": "cd ./backend && npx drizzle-kit migrate",
    "push": "cd ./backend && npx drizzle-kit push",
    "studio": "cd ./backend && npx drizzle-kit studio"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.0",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "eslint": "^10.0.2",
    "husky": "^9.1.7",
    "nano-staged": "^0.9.0"
  },
  "nano-staged": {
    "*.{js,ts,vue,css}": "eslint --fix"
  }
}
